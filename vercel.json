{
  "version": 2,
  "buildCommand": "pnpm install && PORT=3000 BASE_PATH=/ NODE_ENV=production pnpm --filter @workspace/sk-physics run build",
  "outputDirectory": "artifacts/sk-physics/dist/public",
  "functions": {
    "api/index.ts": {
      "maxDuration": 30,
      "memory": 512
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
